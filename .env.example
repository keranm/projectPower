# Growatt OpenAPI credentials
GROWATT_TOKEN=your_growatt_openapi_token_here
GROWATT_SERVER=https://openapi-au.growatt.com/
GROWATT_SPH_SERIAL=your_inverter_serial_number
GROWATT_PLANT_ID=your_plant_id

# Amber Energy API token
AMBER_TOKEN=your_amber_api_token_here

# Your address (used for weather lookup via Open-Meteo/Nominatim)
ADDRESS=Your Street Address, Suburb, Postcode, State

# Safety: keep true until you've reviewed dry-run logs and are confident
DRY_RUN=true

# How often to poll (seconds). 300 = 5 minutes, matches Amber's price interval
POLL_INTERVAL=300

# Price thresholds (cents per kWh)
GRID_CHARGE_MAX_PRICE=10
PRECHARGE_MAX_PRICE=20
